MAXIONBENCH_SLURM_ACCOUNT=your-account
MAXIONBENCH_SLURM_PARTITION=your-partition
MAXIONBENCH_DATASET_ROOT=/project/$USER/maxionbench/dataset
MAXIONBENCH_DATASET_CACHE_DIR=/project/$USER/maxionbench/.cache
MAXIONBENCH_OUTPUT_ROOT=/project/$USER/maxionbench/results
MAXIONBENCH_FIGURES_ROOT=/project/$USER/maxionbench/figures
MAXIONBENCH_HF_CACHE_DIR=/project/$USER/.cache/huggingface
MAXIONBENCH_APPTAINER_MODULE=apptainer
MAXIONBENCH_CONTAINER_IMAGE=/shared/containers/maxionbench.sif
MAXIONBENCH_QDRANT_IMAGE=/shared/containers/qdrant.sif
MAXIONBENCH_PGVECTOR_IMAGE=/shared/containers/pgvector.sif
MAXIONBENCH_OPENSEARCH_IMAGE=/shared/containers/opensearch.sif
MAXIONBENCH_WEAVIATE_IMAGE=/shared/containers/weaviate.sif
MAXIONBENCH_MILVUS_ETCD_IMAGE=/shared/containers/milvus-etcd.sif
MAXIONBENCH_MILVUS_MINIO_IMAGE=/shared/containers/milvus-minio.sif
MAXIONBENCH_MILVUS_IMAGE=/shared/containers/milvus.sif
MAXIONBENCH_CRAG_EXAMPLES=500

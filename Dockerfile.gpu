FROM nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04

ARG MAXIONBENCH_FAISS_GPU_PIP_SPEC=faiss-gpu-cu12>=1.8.0.2

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    ca-certificates \
    curl \
    git \
    libgomp1 \
    python3 \
    python3-dev \
    python3-pip \
    python3-venv \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /opt/maxionbench

COPY pyproject.toml README.md ./
COPY AGENTS.md CLAUDE.md document.md project.md prompt.md ./
COPY maxionbench ./maxionbench
COPY configs ./configs
COPY docs ./docs

RUN ln -sf /usr/bin/python3 /usr/local/bin/python \
 && python -m pip install --upgrade pip setuptools wheel \
 && python -m pip install --index-url https://download.pytorch.org/whl/cu124 "torch==2.6.0" \
 && python -m pip install --no-build-isolation ".[dev,reporting,datasets,rerank]" \
 && python -m pip install \
    "lancedb>=0.7.0" \
    "opensearch-py>=2.6.0" \
    "psycopg[binary]>=3.2.0" \
    "pymilvus>=2.4.0" \
    "qdrant-client>=1.9.0" \
    "weaviate-client>=4.6.0" \
 && python -m pip install "${MAXIONBENCH_FAISS_GPU_PIP_SPEC}"

ENTRYPOINT ["maxionbench"]
CMD ["--help"]
